<?xml version="1.0" encoding="utf-8"?>
<!-- 雨晴Token 前景 · 雨滴 + 阳光 sparkle + 高光 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        配色统一雨晴品牌系：
        · 水滴：草莓粉 #FF85A2（主品牌色）
        · sparkle：樱粉 #FFD1DC（浅层次）
        · 高光：白色
        · 背景：樱粉渐变 #FFF0F5→#FFD1DC→#FFB3C1
    -->

    <!-- 大水滴 · 草莓粉 -->
    <path
        android:pathData="
            M54,30
            Q54,30 44,50
            Q36,62 40,68
            Q44,76 54,76
            Q64,76 68,68
            Q72,62 64,50
            Q54,30 54,30Z"
        android:fillColor="#FF85A2" />

    <!-- 水滴高光 · 白色椭圆 -->
    <path
        android:pathData="M46,54m-3,0a3,2.5 0,1,1 6,0a3,2.5 0,1,1 -6,0"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.75" />

    <!-- sparkle 小太阳 · 樱粉 · 右上角 (72,32) -->
    <path android:pathData="M72,22L72,42"
        android:strokeColor="#FFD1DC" android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />
    <path android:pathData="M62,32L82,32"
        android:strokeColor="#FFD1DC" android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />
    <path android:pathData="M66,26L78,38"
        android:strokeColor="#FFD1DC" android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />
    <path android:pathData="M78,26L66,38"
        android:strokeColor="#FFD1DC" android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />
    <path android:pathData="M72,32m-2.5,0a2.5,2.5 0,1,1 5,0a2.5,2.5 0,1,1 -5,0"
        android:fillColor="#FFD1DC" />

</vector>